{
  "openapi": "3.0.3",
  "info": {
    "title": "Task.sh MCP Server",
    "description": "Model Context Protocol server for Task.sh - Provides task context and export tools for LLMs",
    "version": "1.0.0",
    "contact": {
      "name": "Task.sh API Support"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3002",
      "description": "Development MCP Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API_KEY",
        "description": "API key for authenticating with the MCP server"
      }
    },
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "completed": {"type": "boolean"},
          "date": {"type": "string", "format": "date"},
          "project": {"type": "string", "nullable": true},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"},
          "subtasks": {"type": "array", "items": {"type": "object"}},
          "is_expanded": {"type": "boolean"}
        }
      },
      "Project": {
        "type": "object", 
        "properties": {
          "name": {"type": "string"},
          "task_count": {"type": "integer"},
          "completed_count": {"type": "integer"},
          "pending_count": {"type": "integer"},
          "completion_rate": {"type": "number", "minimum": 0, "maximum": 1},
          "latest_activity": {"type": "number"}
        }
      },
      "ContextResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "context_type": {"type": "string"},
          "user_id": {"type": "string"},
          "timestamp": {"type": "string", "format": "date-time"},
          "data": {"type": "array"},
          "summary": {"type": "object"}
        }
      },
      "ToolResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "tool_result": {
            "type": "object",
            "properties": {
              "format": {"type": "string"},
              "content_type": {"type": "string"},
              "file_extension": {"type": "string"},
              "data": {},
              "filename": {"type": "string"}
            }
          },
          "metadata": {"type": "object"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean", "enum": [false]},
          "error": {"type": "string"},
          "code": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Get MCP server information",
        "description": "Returns information about the MCP server capabilities and endpoints",
        "security": [],
        "responses": {
          "200": {
            "description": "Server information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {"type": "string"},
                    "description": {"type": "string"},
                    "version": {"type": "string"},
                    "capabilities": {"type": "object"},
                    "endpoints": {"type": "object"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health check",
        "description": "Returns the health status of the MCP server",
        "security": [],
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "service": {"type": "string"},
                    "status": {"type": "string"},
                    "timestamp": {"type": "string", "format": "date-time"},
                    "version": {"type": "string"},
                    "environment": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/context/tasks/all": {
      "get": {
        "summary": "Get all tasks",
        "description": "Retrieves all tasks (complete and incomplete) for the authenticated user",
        "responses": {
          "200": {
            "description": "All tasks retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContextResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          }
        }
      }
    },
    "/context/tasks/incomplete": {
      "get": {
        "summary": "Get incomplete tasks",
        "description": "Retrieves all incomplete tasks for the authenticated user",
        "responses": {
          "200": {
            "description": "Incomplete tasks retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContextResponse"}
              }
            }
          }
        }
      }
    },
    "/context/tasks/complete": {
      "get": {
        "summary": "Get completed tasks",
        "description": "Retrieves all completed tasks for the authenticated user",
        "responses": {
          "200": {
            "description": "Completed tasks retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContextResponse"}
              }
            }
          }
        }
      }
    },
    "/context/tasks/due-today": {
      "get": {
        "summary": "Get tasks due today",
        "description": "Retrieves tasks due on the current day for the authenticated user",
        "responses": {
          "200": {
            "description": "Due today tasks retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContextResponse"}
              }
            }
          }
        }
      }
    },
    "/context/tasks/search": {
      "get": {
        "summary": "Search tasks",
        "description": "Searches tasks by description for a given keyword",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "The keyword to search for",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Search results retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContextResponse"}
              }
            }
          },
          "400": {
            "description": "Invalid search query",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          }
        }
      }
    },
    "/context/tasks/{taskId}": {
      "get": {
        "summary": "Get specific task",
        "description": "Retrieves detailed information for a specific task by its ID",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "description": "The unique ID of the task",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Task retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContextResponse"}
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          }
        }
      }
    },
    "/context/projects": {
      "get": {
        "summary": "Get projects summary",
        "description": "Retrieves a summary of all projects with task counts and completion rates",
        "responses": {
          "200": {
            "description": "Projects retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContextResponse"}
              }
            }
          }
        }
      }
    },
    "/context/stats": {
      "get": {
        "summary": "Get user statistics",
        "description": "Retrieves overall statistics about the user's tasks and productivity",
        "responses": {
          "200": {
            "description": "Statistics retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContextResponse"}
              }
            }
          }
        }
      }
    },
    "/tools/export/project": {
      "post": {
        "summary": "Export specific project",
        "description": "Exports tasks from a specific project with optional filtering",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["project_name"],
                "properties": {
                  "project_name": {"type": "string"},
                  "format": {"type": "string", "enum": ["json", "csv", "markdown", "excel"], "default": "json"},
                  "status": {"type": "string", "enum": ["complete", "incomplete", "all"], "default": "all"},
                  "date_from": {"type": "string", "format": "date"},
                  "date_to": {"type": "string", "format": "date"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project exported successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ToolResponse"}
              }
            }
          },
          "404": {
            "description": "Project not found",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          }
        }
      }
    },
    "/tools/export/status": {
      "post": {
        "summary": "Export tasks by status",
        "description": "Exports all tasks filtered by completion status",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {"type": "string", "enum": ["complete", "incomplete"]},
                  "format": {"type": "string", "enum": ["json", "csv", "markdown", "excel"], "default": "json"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status export completed successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ToolResponse"}
              }
            }
          }
        }
      }
    },
    "/tools/export/date-range": {
      "post": {
        "summary": "Export tasks by date range",
        "description": "Exports tasks within a specified date range with optional filtering",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["date_from", "date_to"],
                "properties": {
                  "date_from": {"type": "string", "format": "date"},
                  "date_to": {"type": "string", "format": "date"},
                  "format": {"type": "string", "enum": ["json", "csv", "markdown", "excel"], "default": "json"},
                  "project": {"type": "string"},
                  "status": {"type": "string", "enum": ["complete", "incomplete", "all"], "default": "all"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Date range export completed successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ToolResponse"}
              }
            }
          }
        }
      }
    },
    "/tools/export/bulk": {
      "post": {
        "summary": "Bulk export operations",
        "description": "Performs multiple export operations in a single request",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "projects": {"type": "array", "items": {"type": "string"}},
                  "status_filters": {"type": "array", "items": {"type": "string", "enum": ["complete", "incomplete"]}},
                  "date_ranges": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "start": {"type": "string", "format": "date"},
                        "end": {"type": "string", "format": "date"},
                        "label": {"type": "string"}
                      }
                    }
                  },
                  "format": {"type": "string", "enum": ["json", "csv", "markdown", "excel"], "default": "json"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk export completed successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ToolResponse"}
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Context",
      "description": "Task context endpoints for LLM consumption"
    },
    {
      "name": "Tools", 
      "description": "Export tools for generating formatted task data"
    },
    {
      "name": "Server",
      "description": "Server information and health endpoints"
    }
  ]
}