import { Router, Response } from 'express';
import { body, query, validationResult } from 'express-validator';
import { AuthenticatedRequest } from '../middleware/auth.js';
import { ValidationError, NotFoundError } from '../middleware/errorHandler.js';
import { 
  ApiResponse, 
  ExportRequest, 
  ExportJob, 
  ExportQuery,
  ProjectExportResponse,
  StatusExportResponse,
  DateRangeExportResponse,
  BulkExportRequest,
  BulkExportResponse,
  ApiTask,
  ApiProject
} from '../types/api.js';
import { CloudTaskList } from '../../cloud-task-list.js';
import { TaskList } from '../../task-list.js';
import { convertExportData, setResponseHeaders } from '../utils/formatters.js';

const router = Router();

// Helper to get task list for user
const getTaskListForUser = (userId: string): TaskList => {
  return new CloudTaskList();
};

// Helper to convert internal task to API task
const toApiTask = (task: any): ApiTask => ({
  id: task.id,
  description: task.description,
  completed: task.completed,
  date: task.date,
  project: task.project,
  created_at: task.created_at || new Date().toISOString(),
  updated_at: task.updated_at || new Date().toISOString(),
  subtasks: task.subtasks || [],
  is_expanded: task.isExpanded || false
});

// Validation middleware
const exportValidation = [
  body('format').isIn(['json', 'markdown', 'excel']).withMessage('Format must be json, markdown, or excel')
];

const projectExportValidation = [
  query('status').optional().isIn(['complete', 'incomplete', 'all']).withMessage('Status must be complete, incomplete, or all'),
  query('format').optional().isIn(['json', 'csv', 'excel', 'markdown', 'pdf']).withMessage('Format must be json, csv, excel, markdown, or pdf'),
  query('include').optional().isString().withMessage('Include must be a comma-separated string'),
  query('date_from').optional().isISO8601().withMessage('Date from must be in YYYY-MM-DD format'),
  query('date_to').optional().isISO8601().withMessage('Date to must be in YYYY-MM-DD format')
];

const dateRangeValidation = [
  query('date_from').isISO8601().withMessage('Date from is required and must be in YYYY-MM-DD format'),
  query('date_to').isISO8601().withMessage('Date to is required and must be in YYYY-MM-DD format'),
  query('status').optional().isIn(['complete', 'incomplete', 'all']).withMessage('Status must be complete, incomplete, or all'),
  query('project').optional().isString().withMessage('Project must be a string'),
  query('format').optional().isIn(['json', 'csv', 'excel', 'markdown']).withMessage('Format must be json, csv, excel, or markdown')
];

const bulkExportValidation = [
  body('projects').optional().isArray().withMessage('Projects must be an array'),
  body('date_ranges').optional().isArray().withMessage('Date ranges must be an array'),
  body('status_filters').optional().isArray().withMessage('Status filters must be an array'),
  body('format').optional().isIn(['json', 'csv', 'excel', 'markdown']).withMessage('Format must be json, csv, excel, or markdown'),
  body('compress').optional().isBoolean().withMessage('Compress must be a boolean')
];

// Helper functions
const calculateBusinessDays = (startDate: string, endDate: string): number => {
  const start = new Date(startDate);
  const end = new Date(endDate);
  let businessDays = 0;
  
  for (let d = new Date(start); d <= end; d.setDate(d.getDate() + 1)) {
    const dayOfWeek = d.getDay();
    if (dayOfWeek !== 0 && dayOfWeek !== 6) { // Not Sunday (0) or Saturday (6)
      businessDays++;
    }
  }
  
  return businessDays;
};

const calculateDateDifference = (startDate: string, endDate: string): number => {
  const start = new Date(startDate);
  const end = new Date(endDate);
  const diffTime = Math.abs(end.getTime() - start.getTime());
  return Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1; // +1 to include both start and end dates
};

// POST /api/export - Initiate export
router.post('/', exportValidation, async (req: AuthenticatedRequest, res: Response) => {
  try {
    const errors = validationResult(req);
    if (!errors.isEmpty()) {
      throw new ValidationError('Validation failed', errors.array());
    }

    const exportRequest: ExportRequest = req.body;
    
    // Generate export job ID
    const exportId = `exp_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
    
    // For now, we'll return a mock response
    // In Phase 3, this will actually queue the export job
    const exportJob: ExportJob = {
      id: exportId,
      status: 'pending',
      format: exportRequest.format,
      created_at: new Date().toISOString()
    };

    // TODO: Queue actual export processing
    console.log(`Export job ${exportId} queued for user ${req.user!.id}:`, exportRequest);

    res.status(202).json({
      success: true,
      data: exportJob,
      timestamp: new Date().toISOString()
    } as ApiResponse<ExportJob>);

  } catch (error) {
    console.error('Export initiation error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to initiate export',
      code: 'EXPORT_INITIATION_ERROR',
      timestamp: new Date().toISOString()
    } as ApiResponse);
  }
});

// GET /api/export/date - Export tasks within date range (must come before /:id)
router.get('/date', dateRangeValidation, async (req: AuthenticatedRequest, res: Response) => {
  try {
    const errors = validationResult(req);
    if (!errors.isEmpty()) {
      throw new ValidationError('Validation failed', errors.array());
    }

    const query: ExportQuery = {
      date_from: req.query.date_from as string,
      date_to: req.query.date_to as string,
      status: (req.query.status as any) || 'all',
      project: req.query.project as string,
      format: (req.query.format as any) || 'json'
    };

    const taskList = getTaskListForUser(req.user!.id);
    let filteredTasks = taskList.tasks.filter((task: any) => 
      task.date >= query.date_from! && task.date <= query.date_to!
    );

    // Apply project filter
    if (query.project) {
      filteredTasks = filteredTasks.filter((task: any) => task.project === query.project);
    }

    // Apply status filter
    if (query.status === 'complete') {
      filteredTasks = filteredTasks.filter((task: any) => task.completed === true);
    } else if (query.status === 'incomplete') {
      filteredTasks = filteredTasks.filter((task: any) => task.completed === false);

    // Calculate daily breakdown
    const dailyBreakdown: { [date: string]: { total_tasks: number; completed_tasks: number; pending_tasks: number; completion_rate: number } } = {};
    
    for (let d = new Date(query.date_from!); d <= new Date(query.date_to!); d.setDate(d.getDate() + 1)) {
      const dateStr = d.toISOString().split('T')[0];
      
      const dayTasks = filteredTasks.filter((task: any) => task.date === dateStr);
      const completedCount = dayTasks.filter((task: any) => task.completed).length;
      
      dailyBreakdown[dateStr] = {
        total_tasks: dayTasks.length,
        completed_tasks: completedCount,
        pending_tasks: dayTasks.length - completedCount,
        completion_rate: dayTasks.length > 0 ? completedCount / dayTasks.length : 0
      };
    }

    // Find most/least productive days
    const productivityEntries = Object.entries(dailyBreakdown)
      .filter(([_, data]) => data.total_tasks > 0)
      .sort(([, a], [, b]) => b.total_tasks - a.total_tasks);
    
    const mostProductiveDay = productivityEntries.length > 0 ? productivityEntries[0][0] : query.date_from!;
    const leastProductiveDay = productivityEntries.length > 0 ? productivityEntries[productivityEntries.length - 1][0] : query.date_from!;

    const totalDays = calculateDateDifference(query.date_from!, query.date_to!);
    const businessDays = calculateBusinessDays(query.date_from!, query.date_to!);
    const completedTasks = filteredTasks.filter((task: any) => task.completed).length;

    const exportResponse: DateRangeExportResponse = {
      export_metadata: {
        export_type: 'date_range',
        date_from: query.date_from!,
        date_to: query.date_to!,
        exported_at: new Date().toISOString(),
        exported_by: req.user!.email,
        filters_applied: query,
        version: '1.0'
      },
      date_range: {
        start_date: query.date_from!,
        end_date: query.date_to!,
        total_days: totalDays,
        business_days: businessDays
      },
      tasks: filteredTasks.map(toApiTask),
      daily_breakdown: dailyBreakdown,
      statistics: {
        total_tasks: filteredTasks.length,
        completed_tasks: completedTasks,
        pending_tasks: filteredTasks.length - completedTasks,
        completion_rate: filteredTasks.length > 0 ? completedTasks / filteredTasks.length : 0,
        most_productive_day: mostProductiveDay,
        least_productive_day: leastProductiveDay,
        average_tasks_per_day: filteredTasks.length / totalDays
      }
    };

    res.setHeader('Content-Type', 'application/json');
    res.setHeader('Content-Disposition', `attachment; filename="date-${query.date_from}-to-${query.date_to}-export.json"`);
    
    res.json({
      success: true,
      data: exportResponse,
      timestamp: new Date().toISOString()
    } as ApiResponse<DateRangeExportResponse>);

  } catch (error) {
    console.error('Date range export error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to export date range',
      code: 'DATE_EXPORT_ERROR',
      timestamp: new Date().toISOString()
    } as ApiResponse);
  }
});

