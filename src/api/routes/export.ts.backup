// GET /api/export/projects - List all projects (must come before /:project route)
router.get('/projects', async (req: AuthenticatedRequest, res: Response) => {
  try {
    const taskList = getTaskListForUser(req.user!.id);
    const allTasks = taskList.tasks;
    
    // Group tasks by project
    const projectMap = new Map<string, { tasks: any[], completed: number }>();
    
    for (const task of allTasks) {
      const projectName = task.project || 'No Project';
      
      if (!projectMap.has(projectName)) {
        projectMap.set(projectName, { tasks: [], completed: 0 });
      }
      
      const project = projectMap.get(projectName)!;
      project.tasks.push(task);
      if (task.completed) {
        project.completed++;
      }
    }
    
    // Convert to API format
    const projects: ApiProject[] = Array.from(projectMap.entries()).map(([name, data]) => ({
      name: name === 'No Project' ? null : name,
      task_count: data.tasks.length,
      completed_count: data.completed,
      pending_count: data.tasks.length - data.completed,
      completion_rate: data.tasks.length > 0 ? data.completed / data.tasks.length : 0,
      created_at: Math.min(...data.tasks.map((t: any) => new Date(t.date).getTime())).toString(),
      last_activity: Math.max(...data.tasks.map((t: any) => new Date(t.date).getTime())).toString()
    })).filter(p => p.name !== null);

    res.json({
      success: true,
      data: projects,
      timestamp: new Date().toISOString()
    } as ApiResponse<ApiProject[]>);

  } catch (error) {
    console.error('List projects for export error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to retrieve projects for export',
      code: 'EXPORT_PROJECTS_LIST_ERROR',
      timestamp: new Date().toISOString()
    } as ApiResponse);
  }
});

// GET /api/export/projects/:project - Export specific project with status filtering
router.get('/projects/:project', projectExportValidation, async (req: AuthenticatedRequest, res: Response) => {
  try {
    const errors = validationResult(req);
    if (!errors.isEmpty()) {
      throw new ValidationError('Validation failed', errors.array());
    }

    const { project: projectName } = req.params;
    const query: ExportQuery = {
      status: (req.query.status as any) || 'all',
      format: (req.query.format as any) || 'json',
      include: req.query.include as string,
      date_from: req.query.date_from as string,
      date_to: req.query.date_to as string
    };

    const taskList = getTaskListForUser(req.user!.id);
    let projectTasks = taskList.tasks.filter((task: any) => task.project === projectName);

    if (projectTasks.length === 0) {
      throw new NotFoundError(`Project '${projectName}' not found or has no tasks`);
    }

    // Apply status filtering
    if (query.status === 'complete') {
      projectTasks = projectTasks.filter((task: any) => task.completed === true);
    } else if (query.status === 'incomplete') {
      projectTasks = projectTasks.filter((task: any) => task.completed === false);
    } else if (query.status === 'overdue') {
      const today = new Date().toISOString().split('T')[0];
      projectTasks = projectTasks.filter((task: any) => 
        task.completed === false && task.date < today
      );
    }

    // Apply date filtering
    if (query.date_from && query.date_to) {
      projectTasks = projectTasks.filter((task: any) => 
        task.date >= query.date_from! && task.date <= query.date_to!
      );
    }

    // Calculate project statistics
    const allProjectTasks = taskList.tasks.filter((task: any) => task.project === projectName);
    const completedCount = allProjectTasks.filter((task: any) => task.completed).length;
    const today = new Date().toISOString().split('T')[0];
    const overdueCount = allProjectTasks.filter((task: any) => 
      task.completed === false && task.date < today
    ).length;

    const exportResponse: ProjectExportResponse = {
      export_metadata: {
        export_type: 'project',
        project_name: projectName,
        exported_at: new Date().toISOString(),
        exported_by: req.user!.email,
        filters_applied: query,
        version: '1.0'
      },
      project: {
        name: projectName,
        created_at: Math.min(...allProjectTasks.map((t: any) => new Date(t.date).getTime())).toString(),
        task_count: allProjectTasks.length,
        completed_count: completedCount,
        completion_rate: allProjectTasks.length > 0 ? completedCount / allProjectTasks.length : 0
      },
      tasks: projectTasks.map(toApiTask),
      statistics: {
        total_tasks: projectTasks.length,
        completed_tasks: projectTasks.filter((t: any) => t.completed).length,
        pending_tasks: projectTasks.filter((t: any) => !t.completed).length,
        overdue_tasks: overdueCount,
        completion_rate: projectTasks.length > 0 ? 
          projectTasks.filter((t: any) => t.completed).length / projectTasks.length : 0
      }
    };

    // Handle different formats
    const format = query.format || 'json';
    
    if (format !== 'json') {
      const converted = convertExportData(exportResponse, format, `${projectName}-export`);
      res.setHeader('Content-Type', converted.mimeType);
      res.setHeader('Content-Disposition', `attachment; filename="${projectName}-export.${converted.extension}"`);
      res.send(converted.content);
    } else {
      res.setHeader('Content-Type', 'application/json');
      res.setHeader('Content-Disposition', `attachment; filename="${projectName}-export.json"`);
      res.json({
        success: true,
        data: exportResponse,
        timestamp: new Date().toISOString()
      } as ApiResponse<ProjectExportResponse>);
    }

  } catch (error) {
    if (error instanceof NotFoundError) {
      res.status(404).json({
        success: false,
        error: error.message,
        code: 'PROJECT_NOT_FOUND',
        timestamp: new Date().toISOString()
      } as ApiResponse);
    } else {
      console.error('Project export error:', error);
      res.status(500).json({
        success: false,
        error: 'Failed to export project',
        code: 'PROJECT_EXPORT_ERROR',
        timestamp: new Date().toISOString()
      } as ApiResponse);
    }
  }
});

// GET /api/export/tasks/complete - Export all completed tasks
router.get('/tasks/complete', async (req: AuthenticatedRequest, res: Response) => {
  try {
    const taskList = getTaskListForUser(req.user!.id);
    const completedTasks = taskList.tasks.filter((task: any) => task.completed === true);

    // Group by project for summary
    const projectsSummary: { [key: string]: { task_count: number; completion_rate: number } } = {};
    const allTasksByProject = new Map<string, { total: number; completed: number }>();

    // Calculate project summaries
    for (const task of taskList.tasks) {
      const projectName = task.project || 'No Project';
      if (!allTasksByProject.has(projectName)) {
        allTasksByProject.set(projectName, { total: 0, completed: 0 });
      }
      const project = allTasksByProject.get(projectName)!;
      project.total++;
      if (task.completed) project.completed++;
    }

    allTasksByProject.forEach((stats, projectName) => {
      if (projectName !== 'No Project') {
        projectsSummary[projectName] = {
          task_count: stats.completed,
          completion_rate: stats.completed / stats.total
        };
      }
    });

    const exportResponse: StatusExportResponse = {
      export_metadata: {
        export_type: 'status_filter',
        status_filter: 'complete',
        exported_at: new Date().toISOString(),
        exported_by: req.user!.email
      },
      tasks: completedTasks.map(toApiTask),
      projects_summary: projectsSummary,
      statistics: {
        total_tasks: completedTasks.length,
        projects_affected: Object.keys(projectsSummary).length,
        completion_distribution: Object.fromEntries(
          Object.entries(projectsSummary).map(([project, data]) => [project, data.task_count])
        )
      }
    };

    res.setHeader('Content-Type', 'application/json');
    res.setHeader('Content-Disposition', 'attachment; filename="completed-tasks-export.json"');
    
    res.json({
      success: true,
      data: exportResponse,
      timestamp: new Date().toISOString()
    } as ApiResponse<StatusExportResponse>);

  } catch (error) {
    console.error('Complete tasks export error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to export completed tasks',
      code: 'COMPLETE_TASKS_EXPORT_ERROR',
      timestamp: new Date().toISOString()
    } as ApiResponse);
  }
});

// GET /api/export/tasks/incomplete - Export all incomplete tasks
router.get('/tasks/incomplete', async (req: AuthenticatedRequest, res: Response) => {
  try {
    const taskList = getTaskListForUser(req.user!.id);
    const incompleteTasks = taskList.tasks.filter((task: any) => task.completed === false);

    // Group by project for summary
    const projectsSummary: { [key: string]: { task_count: number; completion_rate: number } } = {};
    const allTasksByProject = new Map<string, { total: number; completed: number }>();

    // Calculate project summaries
    for (const task of taskList.tasks) {
      const projectName = task.project || 'No Project';
      if (!allTasksByProject.has(projectName)) {
        allTasksByProject.set(projectName, { total: 0, completed: 0 });
      }
      const project = allTasksByProject.get(projectName)!;
      project.total++;
      if (task.completed) project.completed++;
    }

    allTasksByProject.forEach((stats, projectName) => {
      if (projectName !== 'No Project' && (stats.total - stats.completed > 0)) {
        projectsSummary[projectName] = {
          task_count: stats.total - stats.completed,
          completion_rate: stats.completed / stats.total
        };
      }
    });

    const exportResponse: StatusExportResponse = {
      export_metadata: {
        export_type: 'status_filter',
        status_filter: 'incomplete',
        exported_at: new Date().toISOString(),
        exported_by: req.user!.email
      },
      tasks: incompleteTasks.map(toApiTask),
      projects_summary: projectsSummary,
      statistics: {
        total_tasks: incompleteTasks.length,
        projects_affected: Object.keys(projectsSummary).length,
        completion_distribution: Object.fromEntries(
          Object.entries(projectsSummary).map(([project, data]) => [project, data.task_count])
        )
      }
    };

    res.setHeader('Content-Type', 'application/json');
    res.setHeader('Content-Disposition', 'attachment; filename="incomplete-tasks-export.json"');
    
    res.json({
      success: true,
      data: exportResponse,
      timestamp: new Date().toISOString()
    } as ApiResponse<StatusExportResponse>);

  } catch (error) {
    console.error('Incomplete tasks export error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to export incomplete tasks',
      code: 'INCOMPLETE_TASKS_EXPORT_ERROR',
      timestamp: new Date().toISOString()
    } as ApiResponse);
  }
});

// POST /api/export/bulk - Bulk export operations (must come before /:id route)
router.post('/bulk', bulkExportValidation, async (req: AuthenticatedRequest, res: Response) => {
  try {
    const errors = validationResult(req);
    if (!errors.isEmpty()) {
      throw new ValidationError('Validation failed', errors.array());
    }

    const bulkRequest: BulkExportRequest = req.body;
    const taskList = getTaskListForUser(req.user!.id);
    const exports: Array<{
      type: 'project' | 'date_range' | 'status_filter';
      identifier: string;
      data: ProjectExportResponse | DateRangeExportResponse | StatusExportResponse;
    }> = [];

    let totalTasks = 0;
    let totalProjects = 0;
    let dateRangeCoverage = 0;

    // Export projects
    if (bulkRequest.projects && bulkRequest.projects.length > 0) {
      for (const projectName of bulkRequest.projects) {
        const projectTasks = taskList.tasks.filter((task: any) => task.project === projectName);
        
        if (projectTasks.length > 0) {
          const completedCount = projectTasks.filter((task: any) => task.completed).length;

          const projectExport: ProjectExportResponse = {
            export_metadata: {
              export_type: 'project',
              project_name: projectName,
              exported_at: new Date().toISOString(),
              exported_by: req.user!.email,
              filters_applied: { status: 'all' },
              version: '1.0'
            },
            project: {
              name: projectName,
              created_at: Math.min(...projectTasks.map((t: any) => new Date(t.date).getTime())).toString(),
              task_count: projectTasks.length,
              completed_count: completedCount,
              completion_rate: completedCount / projectTasks.length
            },
            tasks: projectTasks.map(toApiTask),
            statistics: {
              total_tasks: projectTasks.length,
              completed_tasks: completedCount,
              pending_tasks: projectTasks.length - completedCount,
              completion_rate: completedCount / projectTasks.length
            }
          };

          exports.push({
            type: 'project',
            identifier: projectName,
            data: projectExport
          });

          totalTasks += projectTasks.length;
          totalProjects++;
        }
      }
    }

    // Export date ranges
    if (bulkRequest.date_ranges && bulkRequest.date_ranges.length > 0) {
      for (const dateRange of bulkRequest.date_ranges) {
        const rangeTasks = taskList.tasks.filter((task: any) => 
          task.date >= dateRange.start && task.date <= dateRange.end
        );

        const totalDays = calculateDateDifference(dateRange.start, dateRange.end);
        const businessDays = calculateBusinessDays(dateRange.start, dateRange.end);
        const completedTasks = rangeTasks.filter((task: any) => task.completed).length;

        const dateRangeExport: DateRangeExportResponse = {
          export_metadata: {
            export_type: 'date_range',
            date_from: dateRange.start,
            date_to: dateRange.end,
            exported_at: new Date().toISOString(),
            exported_by: req.user!.email,
            filters_applied: { status: 'all' },
            version: '1.0'
          },
          date_range: {
            start_date: dateRange.start,
            end_date: dateRange.end,
            total_days: totalDays,
            business_days: businessDays
          },
          tasks: rangeTasks.map(toApiTask),
          daily_breakdown: {}, // Simplified for bulk export
          statistics: {
            total_tasks: rangeTasks.length,
            completed_tasks: completedTasks,
            pending_tasks: rangeTasks.length - completedTasks,
            completion_rate: rangeTasks.length > 0 ? completedTasks / rangeTasks.length : 0,
            most_productive_day: dateRange.start,
            least_productive_day: dateRange.end,
            average_tasks_per_day: rangeTasks.length / totalDays
          }
        };

        exports.push({
          type: 'date_range',
          identifier: dateRange.label || `${dateRange.start}-to-${dateRange.end}`,
          data: dateRangeExport
        });

        totalTasks += rangeTasks.length;
        dateRangeCoverage += totalDays;
      }
    }

    // Export status filters
    if (bulkRequest.status_filters && bulkRequest.status_filters.length > 0) {
      for (const statusFilter of bulkRequest.status_filters) {
        let statusTasks = taskList.tasks;
        
        if (statusFilter === 'complete') {
          statusTasks = statusTasks.filter((task: any) => task.completed === true);
        } else if (statusFilter === 'incomplete') {
          statusTasks = statusTasks.filter((task: any) => task.completed === false);

        const statusExport: StatusExportResponse = {
          export_metadata: {
            export_type: 'status_filter',
            status_filter: statusFilter,
            exported_at: new Date().toISOString(),
            exported_by: req.user!.email
          },
          tasks: statusTasks.map(toApiTask),
          projects_summary: {}, // Simplified for bulk
          statistics: {
            total_tasks: statusTasks.length,
            projects_affected: new Set(statusTasks.map((t: any) => t.project).filter(Boolean)).size,
            completion_distribution: {}
          }
        };

        exports.push({
          type: 'status_filter',
          identifier: statusFilter,
          data: statusExport
        });

        totalTasks += statusTasks.length;
      }
    }

    const bulkResponse: BulkExportResponse = {
      export_metadata: {
        export_type: 'bulk',
        exported_at: new Date().toISOString(),
        exported_by: req.user!.email,
        bulk_request: bulkRequest,
        version: '1.0'
      },
      exports,
      summary: {
        total_exports: exports.length,
        total_tasks: totalTasks,
        total_projects: totalProjects,
        date_range_coverage: dateRangeCoverage
      }
    };

    res.setHeader('Content-Type', 'application/json');
    res.setHeader('Content-Disposition', `attachment; filename="bulk-export-${Date.now()}.json"`);
    
    res.json({
      success: true,
      data: bulkResponse,
      timestamp: new Date().toISOString()
    } as ApiResponse<BulkExportResponse>);

  } catch (error) {
    console.error('Bulk export error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to perform bulk export',
      code: 'BULK_EXPORT_ERROR',
      timestamp: new Date().toISOString()
    } as ApiResponse);
  }
});

export { router as exportRoutes };